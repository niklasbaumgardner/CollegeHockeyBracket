{
  "name": "NB Brackets",
  "author": "Niklas Baumgardner",
  "version": "0.0.0",
  "scripts": {
    "tw-watch": "npx @tailwindcss/cli -i ./bracketapp/static/css/src/tailwind.css -o ./bracketapp/static/css/src/tw-out.css --watch",
    "tw-build": "npx @tailwindcss/cli -i ./bracketapp/static/css/src/tailwind.css -o ./bracketapp/static/css/src/tw-out.css",
    "wp-build": "webpack --progress --config ./bracketapp/static/webpack.config.js --mode=production",
    "wp-watch": "webpack --progress --config ./bracketapp/static/webpack.config.js --watch --mode=development",
    "es-build": "node ./bracketapp/static/esbuild.config.mjs",
    "r-build": "rollup --config ./bracketapp/static/rollup.config.mjs",
    "build": "npm run tw-build && npm run wp-build"
  },
  "dependencies": {
    "@awesome.me/webawesome-pro": "^3.1.0",
    "@tailwindcss/cli": "^4.1.18",
    "ag-grid-community": "^35.0.0",
    "lit": "^3.3.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@rollup/plugin-html": "^2.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "assets-webpack-plugin": "^7.1.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "esbuild": "0.27.2",
    "esbuild-clean-plugin": "^2.0.0",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "mini-css-extract-plugin": "^2.9.4",
    "rollup": "^4.57.1",
    "rollup-copy-transform-css": "^2.2.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-postcss": "^4.0.2",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  }
}

{
  "name": "NB Brackets",
  "author": "Niklas Baumgardner",
  "version": "0.0.0",
  "scripts": {
    "tw-watch": "npx @tailwindcss/cli -i ./bracketapp/static/css/src/tailwind.css -o ./bracketapp/static/css/src/tw-out.css --watch",
    "tw-build": "npx @tailwindcss/cli -i ./bracketapp/static/css/src/tailwind.css -o ./bracketapp/static/css/src/tw-out.css",
    "wp-build": "webpack --progress --config ./bracketapp/static/webpack.config.js --mode=production",
    "wp-watch": "webpack --progress --config ./bracketapp/static/webpack.config.js --watch --mode=development",
    "es-build": "node ./bracketapp/static/esbuild.config.mjs",
    "es-watch": "node ./bracketapp/static/esbuild.config.mjs --watch",
    "r-build": "rollup --config ./bracketapp/static/rollup.config.mjs",
    "build": "npm run tw-build && npm run wp-build"
  },
  "dependencies": {
    "@awesome.me/webawesome-pro": "^3.4.0",
    "@tailwindcss/cli": "^4.2.2",
    "ag-grid-community": "^35.2.0",
    "lit": "^3.3.2",
    "profanity-cleaner": "^0.0.3",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "esbuild-clean-plugin": "^2.0.0"
  }
}

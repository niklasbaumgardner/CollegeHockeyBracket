nb-matchup,
nb-edit-matchup,
nb-edit-correct-matchup {
  display: block;
}

.matchup {
  background-color: light-dark(
    var(--wa-color-neutral-95),
    var(--wa-color-neutral-10)
  );

  font-size: var(--wa-font-size-xs);
  box-shadow: var(--wa-shadow-l);
  --spacing: var(--wa-space-2xs);
}

.nb-team {
  width: 100%;
  min-width: 9rem;
  height: 28px;

  display: inline-flex;
  align-items: center;
  padding: var(--wa-space-3xs);
  gap: var(--wa-space-2xs);

  border-radius: var(--wa-panel-border-radius);

  &.user-pick {
    height: 15px;
    padding-block: 0;
    gap: var(--wa-space-2xs);

    .team-name {
      font-size: var(--wa-font-size-2xs);
    }
  }
}

input[type="radio"] {
  margin: 0;

  &:checked {
    accent-color: light-dark(
      var(--wa-color-brand-30),
      var(--wa-color-brand-70)
    );
  }
}

.nb-team:has(input:checked) {
  background-color: light-dark(
    var(--wa-color-brand-95),
    var(--wa-color-brand-05)
  );
  border: 1px solid;
  border-color: light-dark(var(--wa-color-brand-70), var(--wa-color-brand-30));
}

.champion-pick {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

label#top,
label#bottom {
  display: inline-flex;
  gap: var(--wa-space-3xs);
  width: 100%;
}

.team-img {
  width: 18px;
}

.team-img-sm {
  width: 14px;
}

.loser-team {
  color: var(--wa-color-neutral-50);
}

.winner-img {
  padding: 0;
  width: 120px;
  height: 120px;
  min-width: 120px;
  min-height: 120px;
}

.round-one > nb-matchup,
.round-one > nb-edit-matchup,
.round-one > nb-edit-correct-matchup {
  padding: 31px 0;
}

.round-two > nb-matchup {
  padding: 77px 0;
}

.round-three > nb-matchup {
  padding: 205px 0;
}

.bracket-grid-edit .round-two > nb-matchup,
.cbracket-grid .round-two > nb-matchup,
.cbracket-grid-edit .round-two > nb-matchup,
.round-two > nb-edit-matchup,
.round-two > nb-edit-correct-matchup {
  padding: 95px 0;
}

.bracket-grid-edit .round-three > nb-matchup,
.cbracket-grid .round-three > nb-matchup,
.cbracket-grid-edit .round-three > nb-matchup,
.round-three > nb-edit-matchup,
.round-three > nb-edit-correct-matchup {
  padding: 223px 0;
}

.cbracket-grid-edit li > input[type="number"] {
  width: 30px;
  height: 18px;
  float: right;
  appearance: textfield;
  -moz-appearance: textfield;
}

.bracket-grid-edit li input[type="radio"],
.cbracket-grid-edit li input[type="radio"] {
  margin-right: 4px;
}

.bracket-grid,
.bracket-grid-edit,
.cbracket-grid,
.cbracket-grid-edit {
  max-width: 100%;
  display: grid;
  gap: 10px;
  grid-template-columns:
    [round-one-left] minmax(0, 1fr) [round-two-left] minmax(0, 1fr)
    [round-three-left] minmax(0, 1fr) [round-final] minmax(0, 2fr) [round-three-right] minmax(
      0,
      1fr
    )
    [round-two-right] minmax(0, 1fr) [round-one-right] minmax(0, 1fr);
}

.round-one-left {
  grid-area: round-one-left;
}

.round-two-left {
  grid-area: round-two-left;
}

.round-three-left {
  grid-area: round-three-left;
}

.round-final {
  min-width: 274px;
  grid-area: round-final;
}

.round-one-right {
  grid-area: round-one-right;
}

.round-two-right {
  grid-area: round-two-right;
}

.round-three-right {
  grid-area: round-three-right;
}

.final-round-grid {
  display: grid;
  grid-template:
    "top"
    "bottom";
}

.top {
  grid-area: top;
}

.bottom {
  grid-area: bottom;
}

.display-inline-flex {
  display: inline-flex;
}

@media screen and (max-width: 1400px) {
  .bracket-grid,
  .cbracket-grid,
  .bracket-grid-edit,
  .cbracket-grid-edit {
    grid-template:
      "round-one-left round-two-left round-three-left round-final"
      "round-one-right round-two-right round-three-right round-final";
  }
}

@media screen and (max-width: 992px) {
  .bracket-grid,
  .cbracket-grid,
  .bracket-grid-edit,
  .cbracket-grid-edit {
    overflow-x: scroll;
    box-shadow: var(--wa-shadow-l);
    padding: var(--wa-space-s);
  }
}

.champion-grid {
  display: grid;
  grid-template-columns: 1fr;
  justify-items: center;
  grid-template-rows: auto;
  gap: 10px;
}

.championship-grid {
  display: grid;
  grid-template-columns: 1fr;
  justify-items: center;
  grid-template-rows: auto;
  gap: 10px;
}

.champion-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

wa-input[type="number"].goals {
  width: 5rem;
}

wa-input:not([label]) {
  &::part(label) {
    display: none;
  }
}

nb-edit-correct-matchup input[type="number"] {
  width: 30px;
  height: 18px;
  appearance: textfield;
  -moz-appearance: textfield;
}

.round-details {
  --spacing: var(--wa-space-3xs);
  text-align: center;
}

.bracket-details-content {
  font-weight: var(--wa-font-weight-bold);
  padding: var(--wa-space-xs);
  margin: 0;
}

.bracket-details-label {
  white-space: nowrap;
  text-transform: uppercase;
  color: var(--wa-color-text-quiet);
  font-size: var(--wa-font-size-xs);
  padding: var(--wa-space-xs);
}

.bracket-sub-details {
  .bracket-details-content {
    font-size: var(--wa-font-size-xs);
    padding: var(--wa-space-2xs);
  }

  .bracket-details-label {
    font-size: var(--wa-font-size-2xs);
    padding: var(--wa-space-2xs);
  }
}

.wa-light {
  img[src="/static/images/MichiganSt.svg"] {
    filter: brightness(0) saturate(100%) invert(19%) sepia(32%) saturate(892%)
      hue-rotate(104deg) brightness(98%) contrast(93%);
  }
}

wa-icon[name="check-circle"] {
  color: var(--wa-color-success-50);
}

wa-icon[name="x-circle"] {
  color: var(--wa-color-danger-50);
}

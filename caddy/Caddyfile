# global options
{
  admin off # theres no need for the admin api in railway's environment
  persist_config off # storage isn't persistent anyway
  # runtime logs
  log {
    output stdout
    format console
    level DEBUG
  }
  # server options
  servers {
    trusted_proxies static private_ranges # trust railway's proxy
  }
}

# site block, listens on the $PORT environment variable
:{$PORT} {
  # encode zstd

  handle /static* {
    file_server
  }

  header /static* Cache-Control max-age=86400

  # rate limit all POST requests
  rate_limit {
    zone update_settings {
      match {
        method POST
        path /update_settings*
      }
      key {remote_host}
      events 1
      window 1s
    }


    zone post_requests {
      match {
        method POST
        not path /update_settings*
      }
      key {remote_host}
      events 1
      window 10s
    }
  }

  # proxy all requests for /* to the app, configure these variables in the service settings
  reverse_proxy {
    # for private networking replicas are exposed as multiple dns results, use those dns results as the upstreams
    dynamic a {
      name {$APP_DOMAIN}
      port {$APP_PORT}
      refresh 1s
      dial_timeout 30s
      versions ipv4 ipv6
    }

    # configure load balancing settings
    lb_policy round_robin
    lb_retries 100
    lb_try_duration 10s
    lb_try_interval 250ms

    # configure passive health checks
    fail_duration 60s
    max_fails 50
    unhealthy_latency 5s
    unhealthy_request_count 200

    # sets the Host header to the header to the dynamic name and port options
    header_up Host {upstream_hostport}
    header_up X-Request-Start t={time.now.unix_ms}
    header_up Niklas "Niklas"
  }
}
